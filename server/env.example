# Server Configuration
NODE_ENV=development
PORT=3001

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/spatial-website

# JWT Secret (Generate a secure random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Azure Blob Storage Configuration
# Set USE_AZURE_STORAGE to 'true' to enable Azure Blob Storage for images
USE_AZURE_STORAGE=false
AZURE_STORAGE_CONNECTION_STRING=your-azure-storage-connection-string
AZURE_CONTAINER_NAME=spatial-images

# CORS Configuration (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Admin Account (for development only)
ADMIN_EMAIL=admin@spatial.ucsb.edu
ADMIN_PASSWORD=change-this-password
